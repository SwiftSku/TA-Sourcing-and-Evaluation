%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#F5A623', 'primaryBorderColor': '#E09000', 'secondaryColor': '#34A853', 'tertiaryColor': '#FBBC04', 'lineColor': '#555', 'fontSize': '13px'}, 'flowchart': {'nodeSpacing': 30, 'rankSpacing': 40, 'curve': 'basis'}}}%%

flowchart TD
    %% ===== PHASE 0: PRE-FLIGHT =====
    subgraph phase0["Phase 0 · Pre-Flight"]
        USER["👤 Dan answers 4 startup Qs"]
        STARTER["📄 <b>1_Pipeline_Starter.md</b><br/>Role selection → JD config → run params<br/>Canary token · Hard cap 60 · A-target 20"]
        ORCH["🟡 <b>2_Pipeline_Orchestrator.md</b> · Opus<br/>Role-agnostic · NO Chrome · spawns sub-agents<br/>Company-targeted: Tier 1 → Tier 2 → keyword fallback"]
        COMPANY_RESEARCH["🟢 <b>Target_Companies/Company_Research_Agent.md</b> · Sonnet<br/>Parallel: finds US-HQ B2B SaaS w/ Gujarat office<br/>→ Target_Companies/company_research.json → feeds Tier 2"]
        PREFLIGHT_CLEAN["🟢 <b>Pre-flight Cleanup</b> · Sonnet"]
        USER --> STARTER --> ORCH
        ORCH -.->|"parallel (no Chrome)"| PREFLIGHT_CLEAN
        ORCH -.->|"parallel (no Chrome)"| COMPANY_RESEARCH
    end

    %% ===== SOURCE DECISION =====
    SRC{"🔶 Source type?"}

    %% ===== PHASE 1: URL EXTRACTION =====
    subgraph phase1["Phase 1 · URL Extraction"]
        URL_EXT["🟢 <b>URL_Extractor.md</b> · Sonnet<br/>Verify filters READ-ONLY · pre-filter neg keywords<br/>Extract 5 non-dup URLs · validate regex<br/>PAGE/POS tracking · exhaustion flags"]
    end

    %% ===== STATIC SOURCE =====
    subgraph static["Phase 1 · Static Source"]
        STATIC_DEDUP["🟡 <b>Orchestrator dedup</b><br/>Name + normalized LI URL check<br/>No URL Extractor for static sources"]
    end

    %% ===== PHASE 2: CANDIDATE EVALUATION =====
    subgraph phase2["Phase 2 · Evaluate (1 at a time)"]
        CE["🟢 <b>Candidate Evaluator</b> · Sonnet<br/>Reads active JD rubric · auto-DQ · full scroll<br/>Score dims (base + bonus) · write row immediately"]
        HANDOFF["🟡 Update <b>Z_Search_Cache.json</b><br/>top5_summary + a_rated_cache"]
        DELAY["⏱️ 45-200s delay (LinkedIn only)"]
        CE --> HANDOFF --> DELAY
    end

    %% ===== PHASE 3: DECISIONS =====
    subgraph phase3["Phase 3 · Quality Gates"]
        QG{"🔶 <b>Quality Gate</b><br/>Initial: ≥1 A in first 5?<br/>Rolling: ≥1 A in last 5?<br/>0 A in last 10 → dead"}
        REFINE["🟣 <b>Search Refinement</b><br/>Next company or adjust filters"]
    end

    %% ===== PHASE 4: CLEANUP =====
    subgraph phase4["Phase 4 · Cleanup (every 10 + final)"]
        CLEANUP["🟢 <b>Cleanup Agent</b> · Sonnet<br/>Rubric change → rescore ALL · normalize URLs<br/>Dedup · validation suite · re-eval broken rows<br/>Enrich: fill missing URLs + names via Chrome<br/>Cleaned? = TRUE / DUPLICATE / ENRICHMENT_FAILED"]
        CG{"🔶 Uncleaned = 0?<br/>HARD gate on final"}
        CLEANUP --> CG
    end

    %% ===== TERMINATION CHECK =====
    CAP{"🔶 <b>60 total? 20 A?</b><br/>Canary? Compaction?"}

    %% ===== PIPELINE COMPLETE =====
    subgraph complete["Pipeline Complete"]
        SUMMARY["🟡 <b>Output Summary · STOP</b><br/>Tier breakdown + A/B candidate lists"]
    end

    %% ===== SELF-DESTRUCT =====
    subgraph destruct["🔴 Self-Destruct"]
        SD["<b>Context_Legacy_Prompt.md → STOP</b><br/>Resume prompt: source, page/pos, counters, cache<br/>New session reads it + fresh canary"]
    end

    %% ===== MANUAL — SEPARATE INVOCATION =====
    subgraph manual["🔧 MANUAL — Separate Invocation"]
        SAVE["👤 <b>Save_To_LIR.md</b><br/>Double confirmation · badge check · 30-90s delay"]
    end

    %% ===== SHARED FILES =====
    subgraph shared["📁 Shared Files"]
        direction LR
        FILES["<b>[output file]</b> · <b>Z_Search_Cache.json</b> · <b>Target_Companies/company_research.json</b><br/><b>Chat_Log-*.md</b> · <b>Error_Log.md</b> · <b>LIR_Learnings.md</b> · <b>Context_Legacy_Prompt.md</b>"]
    end

    %% ===== CONNECTIONS =====
    PREFLIGHT_CLEAN -->|"must finish"| SRC
    SRC -->|"LinkedIn Recruiter"| URL_EXT
    SRC -->|"Static (PDF/spreadsheet)"| STATIC_DEDUP

    URL_EXT --> CE
    STATIC_DEDUP --> CE
    DELAY -->|"Next cand (×5)"| CE
    DELAY -->|"Batch done"| QG

    QG -->|"✅ Pass (every 10)"| CLEANUP
    QG -->|"❌ Fail (0 A in 10)"| REFINE
    REFINE -->|"Fresh extractor"| URL_EXT

    CG -->|"✅ Pass"| CAP
    CG -.->|"❌ re-clean"| CLEANUP

    CAP -->|"No → next batch"| SRC
    CAP -->|"Yes → done"| SUMMARY
    CAP -.->|"Canary/compaction"| SD

    COMPANY_RESEARCH -.->|"feeds Tier 2"| ORCH

    %% ===== STYLES =====
    classDef user fill:#4285F4,stroke:#3367D6,color:#fff,stroke-width:2px
    classDef opus fill:#F5A623,stroke:#E09000,color:#fff,stroke-width:2px
    classDef sonnet fill:#34A853,stroke:#2E8B47,color:#fff,stroke-width:2px
    classDef decision fill:#FBBC04,stroke:#E0A800,color:#333,stroke-width:2px
    classDef refine fill:#E8D5F5,stroke:#7B4DB5,color:#333,stroke-width:2px
    classDef destructNode fill:#EA4335,stroke:#C62828,color:#fff,stroke-width:2px
    classDef phaseStyle fill:#f8f9fa,stroke:#bdc3c7,stroke-width:1px
    classDef sharedStyle fill:#E8EAF6,stroke:#5C6BC0,stroke-width:1px

    class USER user
    class STARTER,ORCH,HANDOFF,SUMMARY,STATIC_DEDUP opus
    class PREFLIGHT_CLEAN,URL_EXT,CE,CLEANUP,COMPANY_RESEARCH sonnet
    class QG,CG,CAP,SRC decision
    class REFINE refine
    class SD destructNode
    class DELAY opus
    class SAVE user
    class FILES sonnet

    class phase0,phase1,phase2,phase3,phase4,complete,static phaseStyle
    class shared sharedStyle

    style destruct fill:#FFEBEE,stroke:#EA4335,stroke-width:2px
    style manual fill:#E3F2FD,stroke:#4285F4,stroke-width:2px,stroke-dasharray:5
